###############################################################################
# SARIBLOG - Tests API REST Client
# Fichier : Back/tests/api.http
###############################################################################
# 📝 NOTES D'UTILISATION
###############################################################################
#
# 🚀 DÉMARRAGE
# 1. Installer l'extension REST Client (par Huachao Mao) dans VS Code
# 2. Démarrer le serveur : npm run dev (dans Back/)
# 3. Cliquer sur "Send Request" au-dessus de chaque requête
#    (ou Ctrl+Alt+R / Cmd+Alt+R avec le curseur sur la requête)
#
# 🔐 AUTHENTIFICATION (pour tester les routes admin et /users/me)
# 1. Aller à la section "AUTH" ci-dessous (ligne ~44)
# 2. Dans la requête "POST {{baseUrl}}/auth/login", remplacer les identifiants par les vôtres
# 3. Cliquer sur "Send Request" pour vous connecter
# 4. Dans la réponse, copier la valeur de "accessToken"
# 5. La coller dans la variable @accessToken (ligne ~34)
# 6. Les routes admin fonctionneront automatiquement avec ce token
#
# 📊 CODES HTTP COURANTS
# - 200 = Succès
# - 401 = Non authentifié (token manquant/invalide)
# - 403 = Non autorisé (rôle insuffisant)
# - 404 = Ressource introuvable
#
###############################################################################

### Variables globales
@baseUrl = http://localhost:4242/api
@adminUrl = http://localhost:4242/api/admin
# Après login, copier l'accessToken ici pour tester les routes admin et /users/me
@accessToken = votre_access_token_ici

###############################################################################
# 🏠 TEST SERVEUR
###############################################################################

### Vérifier que le serveur tourne
GET http://localhost:4242/

###############################################################################
# 🔐 AUTH (login, signup, refresh, logout)
###############################################################################

### 1. Connexion (login) - récupère accessToken + user, définit cookie refreshToken
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "identifier": "admin@example.com",
  "password": "votre_mot_de_passe"
}

### 2. Rafraîchir l'access token (utilise le cookie refreshToken)
POST {{baseUrl}}/auth/refresh

### 3. Déconnexion (logout) - invalide le refresh token et supprime le cookie
POST {{baseUrl}}/auth/logout

###############################################################################
# 📰 ARTICLES (public)
###############################################################################

### 1. Preview homepage (4 derniers articles publiés)
GET {{baseUrl}}/articles/homepage-preview

### 2. Liste articles PUBLIÉS uniquement (public)
GET {{baseUrl}}/articles/published

### 3. Liste articles PUBLIÉS avec limite (public - max 20)
GET {{baseUrl}}/articles/published?limit=4

### 4. Article publié par ID (public)
GET {{baseUrl}}/articles/published/id/1

### 5. Article publié par SLUG (public)
GET {{baseUrl}}/articles/published/slug/tutoriel-peindre-dragon

###############################################################################
# 📰 ARTICLES ADMIN (authentification requise : Authorization Bearer)
###############################################################################

### 1. Liste TOUS les articles (admin - tous statuts)
GET {{adminUrl}}/articles
Authorization: Bearer {{accessToken}}

### 2. Article par SLUG (admin)
GET {{adminUrl}}/articles/slug/decouvrir-aquarelle-guide-debutants
Authorization: Bearer {{accessToken}}

### 3. Article par ID (admin - détails complets)
GET {{adminUrl}}/articles/1
Authorization: Bearer {{accessToken}}

### 4. Créer un article (POST - admin)
POST {{adminUrl}}/articles
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "Nouvel article",
  "slug": "nouvel-article",
  "content": "Contenu de l'article...",
  "status": "draft",
  "featured_image_id": 1
}

### 5. Modifier un article (PATCH - admin)
PATCH {{adminUrl}}/articles/1
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "Titre modifié",
  "status": "published"
}

### 6. Supprimer un article (DELETE - admin)
DELETE {{adminUrl}}/articles/1
Authorization: Bearer {{accessToken}}

###############################################################################
# 📊 DASHBOARD ADMIN (authentification requise : Authorization Bearer)
###############################################################################

### 1. Statistiques globales
GET {{adminUrl}}/dashboard/stats
Authorization: Bearer {{accessToken}}

###############################################################################
# 🖼️ IMAGES (admin - authentification requise : Authorization Bearer)
###############################################################################

### 1. Liste paginée (admin - tous champs, filtre tagId optionnel)
GET {{adminUrl}}/images?page=1&limit=10&tagId=1
Authorization: Bearer {{accessToken}}

### 2. Image par ID (admin)
GET {{adminUrl}}/images/1
Authorization: Bearer {{accessToken}}

### 3. Créer une image (POST - admin)
POST {{adminUrl}}/images
Authorization: Bearer {{accessToken}}
# IMPORTANT: `POST /admin/images` nécessite `multipart/form-data` avec un fichier dans le champ `image`.
# Dans l'extension REST Client, configure en `form-data` :
# - image: (fichier)
# - title: "Nouvelle image"
# - description: "Description..."
# - alt_descr: "Texte alternatif..."
# - is_in_gallery: true
# - article_id: 1
# - tag_ids: [1,2] (ou JSON string)

### 4. Modifier une image (PATCH - admin)
PATCH {{adminUrl}}/images/1
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "Image modifiée",
  "description": "Description modifiée",
  "alt_descr": "Texte alternatif modifié",
  "is_in_gallery": true,
  "article_id": 1,
  "tag_ids": [1, 2]
}

### 5. Supprimer une image (DELETE - admin)
DELETE {{adminUrl}}/images/1
Authorization: Bearer {{accessToken}}

###############################################################################
# 🏷️ TAGS (admin - authentification requise : Authorization Bearer)
###############################################################################

### 1. Liste tous les tags
GET {{adminUrl}}/tags
Authorization: Bearer {{accessToken}}

### 2. Tags utilisés sur des articles (admin)
GET {{adminUrl}}/tags/used-on-articles
Authorization: Bearer {{accessToken}}

### 3. Tags utilisés sur des images (admin)
GET {{adminUrl}}/tags/used-on-images
Authorization: Bearer {{accessToken}}

### 4. Tag par ID (admin)
GET {{adminUrl}}/tags/1
Authorization: Bearer {{accessToken}}

### 5. Créer un tag (POST - admin)
POST {{adminUrl}}/tags
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Tag de test",
  "slug": "tag-de-test"
}

### 6. Modifier un tag (PATCH - admin)
PATCH {{adminUrl}}/tags/1
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Tag modifié"
}

### 7. Supprimer un tag (DELETE - admin)
DELETE {{adminUrl}}/tags/1
Authorization: Bearer {{accessToken}}

