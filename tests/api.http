# 👥 USERS (public + admin)
###############################################################################

### 1. Artiste principale (public)
GET {{baseUrl}}/users/artist

### 2. Utilisateur connecté (admin - nécessite Bearer token)
GET {{adminUrl}}/users/me
Authorization: Bearer {{accessToken}}

### 3. Mettre à jour le profil (PATCH - admin)
PATCH {{adminUrl}}/users/me
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "username": "nouvel_user",
  "email": "newuser@example.com",
  "bio_short": "Bio courte mise à jour"
}

### 4. Mettre à jour le mot de passe (PATCH - admin)
PATCH {{adminUrl}}/users/me/password
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "password": "NouveauMotDePasse123!"
}

